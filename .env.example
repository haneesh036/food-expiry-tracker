# ------------------------------
# Backend Environment Variables
# ------------------------------

# Port to run the server on (default: 5000)
PORT=5000

# Set to 'production' when deploying
NODE_ENV=production

# JWT Secret for authentication (Change this to a secure random string!)
JWT_SECRET=super_secret_key_change_me_in_production

# ------------------------------
# Frontend Environment Variables
# ------------------------------
# In production, the backend serves the frontend, so VITE_API_URL can be blank.
# During local development, you might set it to http://localhost:5000
VITE_API_URL=
